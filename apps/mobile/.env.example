# =============================================================================
# apps/mobile — example environment (TEMPLATE — NO real secrets)
# Copy to apps/mobile/.env for local dev. Real .env files are gitignored.
#
# MOBILE RULE: only EXPO_PUBLIC_* vars are bundled into the client, so this file
# contains PUBLIC / anon-safe values ONLY:
#   - NO service role key
#   - NO private / server-side API keys
#   - NO AI keys
#   - NO production secrets
# (See /docs/07_SECURITY_RLS.md §8 — the service role is never on the client.)
# =============================================================================

EXPO_PUBLIC_APP_ENV=local
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=
EXPO_PUBLIC_SENTRY_DSN=
