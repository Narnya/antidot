# =============================================================================
# apps/admin — example environment (TEMPLATE — NO real secrets)
# Copy to apps/admin/.env.local for local dev. Real .env files are gitignored.
#
# NAMING: NEXT_PUBLIC_* is exposed to the browser bundle (PUBLIC ONLY).
# Unprefixed vars are SERVER-ONLY and must never reach client components.
# =============================================================================

# --- Public (browser-safe) ---------------------------------------------------
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_SENTRY_DSN=

# --- Server-only (NEVER exposed to client components) ------------------------
# - SUPABASE_SERVICE_ROLE_KEY bypasses RLS — server-side only.
# - Never expose these to client components or behind a NEXT_PUBLIC_ prefix.
# - Admin auth/authorization will be implemented later (not in INFRA-006).
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_ALLOWED_EMAILS=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
